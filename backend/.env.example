# Copy this file to .env and fill in your actual values.
# Never commit the real .env file to source control.

# ── Azure SQL Databases ────────────────────────────────────────────────────
SOURCE_DB_CONN=mssql+pyodbc://user:password@yourserver.database.windows.net/sourcedb?driver=ODBC+Driver+18+for+SQL+Server
TARGET_DB_CONN=mssql+pyodbc://user:password@yourserver.database.windows.net/targetdb?driver=ODBC+Driver+18+for+SQL+Server

# ── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-openai-key-here...
OPENAI_MODEL=gpt-4o

# ── Azure Key Vault (optional — leave blank for local dev) ─────────────────
KEY_VAULT_URL=
